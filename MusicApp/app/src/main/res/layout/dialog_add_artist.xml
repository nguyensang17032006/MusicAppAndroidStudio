<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/S20">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tìm nghệ sĩ"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etSearchArtist"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Nhập tên nghệ sĩ..."
        android:textColor="@color/white"
        android:textColorHint="@color/S60"
        android:background="@drawable/bg_mini_player"
        android:paddingHorizontal="12dp"
        android:maxLines="1"
        android:singleLine="true" />

    <TextView
        android:id="@+id/tvEmptyArtists"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="Không có nghệ sĩ nào"
        android:textColor="@color/S60"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvArtistResults"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_marginTop="8dp" />

</LinearLayout>
