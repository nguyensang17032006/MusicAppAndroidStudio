<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header: Title, Search, Plus -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_library_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="Your Library"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_library_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="8dp"
                android:layout_toStartOf="@id/btn_library_search"
                android:background="@drawable/bg_search_input"
                android:hint="Tìm trong thư viện..."
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:padding="8dp"
                android:textColor="@color/white"
                android:textColorHint="@color/S60"
                android:textSize="14sp"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/btn_library_search"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_centerVertical="true"
                android:layout_marginEnd="16dp"
                android:layout_toStartOf="@+id/btn_library_add"
                android:src="@drawable/ic_search"
                app:tint="@color/white" />

            <ImageView
                android:id="@+id/btn_library_add"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_plus"
                app:tint="@color/white" />
        </RelativeLayout>

        <!-- Filter Chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chipPlaylists"
                    style="@style/LibraryFilterChip"
                    android:text="Playlists" />

                <TextView
                    android:id="@+id/chipArtists"
                    style="@style/LibraryFilterChip"
                    android:text="Artists" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Sort and View mode -->
        <RelativeLayout
            android:id="@+id/layoutSort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_sort"
                    app:tint="@color/white" />

                <TextView
                    android:id="@+id/tvSortMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Gần đây"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_alignParentEnd="true"
                android:src="@drawable/ic_grid"
                app:tint="@color/white" />
        </RelativeLayout>

        <!-- Library Items List -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Item: Liked Songs -->
            <RelativeLayout
                android:id="@+id/btn_liked_songs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/item_img_1"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@color/S20"
                    android:padding="16dp"
                    android:src="@drawable/ic_music_note"
                    app:shapeAppearanceOverlay="@style/RoundedCorners8" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp"
                    android:layout_toEndOf="@id/item_img_1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Liked Songs"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_liked_songs_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 bài hát"
                        android:textColor="@color/S60"
                        android:textSize="14sp" />
                </LinearLayout>
            </RelativeLayout>

            <!-- Playlists List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_playlists"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- Artists List (Hidden by default) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_artists"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:visibility="gone"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- Item: Add Playlist -->
            <RelativeLayout
                android:id="@+id/btn_add_playlist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/item_img_5"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@color/S20"
                    android:padding="20dp"
                    android:src="@drawable/ic_plus"
                    app:shapeAppearanceOverlay="@style/RoundedCorners8"
                    app:tint="@color/S60" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp"
                    android:layout_toEndOf="@id/item_img_5"
                    android:text="Add playlist"
                    android:textColor="@color/white"
                    android:textSize="16sp" />
            </RelativeLayout>

            <!-- Item: Add Artist -->
            <RelativeLayout
                android:id="@+id/btn_add_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="visible">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/item_img_artist_plus"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@color/S20"
                    android:padding="20dp"
                    android:src="@drawable/ic_plus"
                    app:shapeAppearanceOverlay="@style/CircleImage"
                    app:tint="@color/S60" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp"
                    android:layout_toEndOf="@id/item_img_artist_plus"
                    android:text="Add artist"
                    android:textColor="@color/white"
                    android:textSize="16sp" />
            </RelativeLayout>

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>